{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/messages/route.ts": {
      "maxDuration": 10
    },
    "app/api/vision/analyze/route.ts": {
      "maxDuration": 30
    },
    "app/api/stt/route.ts": {
      "maxDuration": 30
    },
    "app/api/tts/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/run/route.ts": {
      "maxDuration": 30
    },
    "app/api/agi/run/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/run",
      "schedule": "0 0 * * *"
    }
  ]
}
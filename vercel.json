{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/messages/route.ts": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/agent-poll",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/deliver",
      "schedule": "*/2 * * * *"
    }
  ]
}

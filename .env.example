# ── Deployment Mode ───────────────────────────────────────────────────────────
# Choose where Shivver stores its data.
# - 'local': SQLite + filesystem on this machine (no cloud services)
# - 'cloud': Supabase + Vercel (requires SUPABASE_URL, SUPABASE_ANON_KEY)
SHIVVER_MODE=local

# ── Local Storage Paths ───────────────────────────────────────────────────────
# Where to store SQLite DB and asset files (used only in local mode)
SHIVVER_DATA_DIR=~/.shivver          # or %APPDATA%/Shivver on Windows
SHIVVER_DB_PATH=shivver.db           # filename inside data dir
SHIVVER_STORAGE_DIR=storage          # subdirectory for TTS, images, etc.

# ── Database ─────────────────────────────────────────────────────────────────
# Option A: Local SQLite (if SHIVVER_MODE=local, DATABASE_URL not required)
# Option B: PostgreSQL (for cloud or local Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/shivver

# ── LLM Provider Configuration ───────────────────────────────────────────
# Choose your AI provider. Bring your own API key.
# Options: openai, groq, anthropic, gemini, ollama (local)
DEFAULT_LLM_PROVIDER=openai

# Provider priority order for failover (comma-separated)
# When one provider hits rate limits, Shivver auto-switches to the next
LLM_PROVIDER_ORDER=openai,groq,anthropic,gemini,ollama

# ── OpenAI (GPT-4, GPT-3.5) ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Multiple OpenAI keys for rotation (comma-separated)
OPENAI_KEYS=

# ── Groq (Llama 3, Mixtral — ultra-fast) ─────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
# Multiple Groq keys for rotation (comma-separated)
GROQ_KEYS=

# ── Anthropic (Claude 3.5 Sonnet) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Google AI (Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── Ollama (local models) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:70b

# ── OpenAI (required for legacy paths) ───────────────────────────────────────
# (Kept for backwards compatibility; use provider-specific keys above)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Supabase (required for cloud mode, optional for local) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Voice (ElevenLabs) ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=eleven_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel

# ── Search (Exa) ─────────────────────────────────────────────────────────────
EXA_API_KEY=exa_...

# ── Google Drive (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── App URL (for OAuth redirects) ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000          # dev
# NEXTPUBLIC_APP_URL=https://your-app.vercel.app   # production
